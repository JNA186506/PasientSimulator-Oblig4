<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
			 xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
			 x:Class="Assessment.CasePage">
	<Grid>
		<Grid.ColumnDefinitions>
			<ColumnDefinition Width="*" />
			<ColumnDefinition Width="*" />
			<ColumnDefinition Width="200" />
		</Grid.ColumnDefinitions>
		<Grid.RowDefinitions>
			<RowDefinition Height="2*" />
			<RowDefinition Height="*" />
		</Grid.RowDefinitions>

		<Label Grid.Row="0" Grid.Column="0" >
			<Label.FormattedText>
				<FormattedString>
					<Span Text="CASE #" FontSize="24" FontAttributes="Bold"  /> 
					<Span Text="{Binding CaseId}" FontSize="24" FontAttributes="Bold" />
				</FormattedString>
			</Label.FormattedText>
		</Label>

		<StackLayout Grid.Column="2" Grid.Row="0">
			<Label Text="Kommentarer:" FontSize="20" />
		</StackLayout>
		
			<Label Grid.Column="0" Grid.Row="1">
				<Label.FormattedText>
					<FormattedString>
						<Span Text="Patient: " FontSize="16" /> 
						<Span Text="{Binding CasePatient.PatientName}" FontSize="16" FontAttributes="Bold"/>
					</FormattedString>
				</Label.FormattedText>
			</Label>

			<Label Grid.Column="1" Grid.Row="1">
				<Label.FormattedText>
					<FormattedString>
						<Span Text="Student: " FontSize="16" /> 
						<Span Text="{Binding Student.Name}" FontSize="16" FontAttributes="Bold"/>
					</FormattedString>
				</Label.FormattedText>
			</Label>
		
	</Grid>
</ContentPage>