<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             x:Class="Assessment.MainPage">
    <Grid>
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="300" />
            <ColumnDefinition Width="*" />
        </Grid.ColumnDefinitions>
        
        <Grid Column="1">
            <CollectionView x:Name="CaseView">
                <CollectionView.ItemTemplate>
                    <DataTemplate>
                        <Border StrokeThickness="1" 
                                BackgroundColor="AliceBlue"
                                StrokeShape="RoundRectangle, 30" 
                                Padding="15"
                                Margin="20">
                            <Grid Padding="10">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*" />
                                    <ColumnDefinition Width="*" />
                                </Grid.ColumnDefinitions>
                                <Grid.RowDefinitions>
                                    <RowDefinition Height="*" />
                                    <RowDefinition Height="*" />
                                    <RowDefinition Height="*" />
                                    <RowDefinition Height="*" />
                                    <RowDefinition Height="*" />
                                    <RowDefinition Height="50" />
                                </Grid.RowDefinitions>
                                <Label Grid.Row="0" Grid.Column="0" >
                                    <Label.FormattedText>
                                        <FormattedString>
                                            <Span Text="CASE #" FontSize="24" FontAttributes="Bold"  /> 
                                            <Span Text="{Binding CaseId }" FontSize="24" FontAttributes="Bold"/>
                                        </FormattedString>
                                    </Label.FormattedText>
                                </Label>
                                <Label Grid.Row="1" Grid.Column="0" >
                                   <Label.FormattedText>
                                       <FormattedString>
                                           <Span Text="Patient: " FontSize="16" /> 
                                           <Span Text="{Binding CasePatient.PatientName}" FontSize="16" FontAttributes="Bold"/>
                                       </FormattedString>
                                   </Label.FormattedText>
                                </Label>
                                <Label Grid.Row="1" Grid.Column="1">
                                    <Label.FormattedText>
                                        <FormattedString>
                                            <Span Text="Student: " FontSize="16" />
                                            <Span Text="{Binding Student.Name }" FontSize="16" FontAttributes="Bold"/>
                                        </FormattedString>
                                    </Label.FormattedText>
                                </Label>
                                <Label Grid.Row="2" Grid.Column="0">
                                    <Label.FormattedText>
                                        <FormattedString>
                                            <Span Text="Patient status: " FontSize="16" />
                                            <Span Text="{Binding CasePatient.Status }" FontSize="16" FontAttributes="Bold"/>
                                        </FormattedString>
                                    </Label.FormattedText>
                                </Label>
                                <Label Grid.Row="3" Grid.Column="0">
                                    <Label.FormattedText>
                                        <FormattedString>
                                            <Span Text="Current Temperature: " FontSize="16" />
                                            <Span Text="{Binding CasePatient.Temperature }" FontSize="16" FontAttributes="Bold"/>
                                        </FormattedString>
                                    </Label.FormattedText>
                                </Label>
                                <Button Grid.Row="5" Grid.Column="1" 
                                        Text="View Case"
                                        MaximumWidthRequest="100"
                                        HorizontalOptions="Start"/>
                            </Grid>
                        </Border>
                    </DataTemplate>
                </CollectionView.ItemTemplate>
            </CollectionView>
        </Grid>
        
        
        
    </Grid>

</ContentPage>
